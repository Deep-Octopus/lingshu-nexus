# LingShu Nexus local development configuration.
# Copy to `.env` and replace placeholder values before running real services.

APP_ENV=development
APP_NAME=LingShu Nexus
APP_HOST=0.0.0.0
APP_PORT=8000
DEFAULT_DOMAIN_ID=acupuncture

# MiMo provider placeholders. Do not commit real keys.
MIMO_API_KEY=replace-with-mimo-api-key
MIMO_BASE_URL=https://mimo.example.invalid/v1
MIMO_MODEL_ID=replace-with-mimo-model-id

# Business database.
DATABASE_URL=postgresql://lingshu:change-me-postgres-password@localhost:5432/lingshu_nexus

# Queue/cache.
REDIS_URL=redis://localhost:6379/0

# Object storage.
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=lingshu-documents
OBJECT_STORAGE_LOCAL_PATH=data/runtime/object-store
OBJECT_STORAGE_ACCESS_KEY=replace-with-minio-access-key
OBJECT_STORAGE_SECRET_KEY=replace-with-minio-secret-key
OBJECT_STORAGE_SECURE=false

# Upload limits.
DOCUMENT_MAX_UPLOAD_BYTES=20971520

# Graph database.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace-with-neo4j-password
